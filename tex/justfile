default:
    @just --list

# Build all TeX publications and copy PDFs into tex/dist/
build-all:
    #!/usr/bin/env bash
    set -euo pipefail

    books=(research-radar)

    mkdir -p dist

    for book in "${books[@]}"; do
      echo "=== Building ${book} ==="
      (cd "${book}" && just build)
      echo "Built: dist/${book}.pdf"
    done

clean:
    #!/usr/bin/env bash
    set -euo pipefail

    for book in research-radar; do
      rm -f "${book}"/*.aux "${book}"/*.log "${book}"/*.out "${book}"/*.toc "${book}"/*.synctex.gz "${book}"/*.fls "${book}"/*.fdb_latexmk "${book}"/*.pdf || true
      rm -f "${book}"/chapters/*.aux || true
    done

    rm -rf dist
